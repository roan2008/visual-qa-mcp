{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-qa-mcp.local/schemas/arrow-evidence-graph.schema.json",
  "title": "ArrowEvidenceGraph",
  "type": "object",
  "required": [
    "image_id",
    "diagram_type",
    "arrows",
    "regions",
    "extraction_confidence",
    "provenance",
    "gaps",
    "metadata"
  ],
  "properties": {
    "image_id": {"type": "string"},
    "diagram_type": {"type": "string"},
    "arrows": {
      "type": "array",
      "items": {"$ref": "#/$defs/arrow"}
    },
    "regions": {
      "type": "array",
      "items": {"$ref": "#/$defs/region"}
    },
    "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {
      "type": "object",
      "required": ["extractor_id", "extractor_version", "backend", "metadata_source"],
      "properties": {
        "extractor_id": {"type": "string"},
        "extractor_version": {"type": "string"},
        "backend": {"type": "string"},
        "metadata_source": {"type": "string"},
        "dependency_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "environment": {"type": "object", "additionalProperties": true}
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "check_ids"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "check_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "arrow": {
      "type": "object",
      "required": [
        "arrow_id",
        "rgb",
        "bbox",
        "tail_xy",
        "head_xy",
        "angle_degrees",
        "length_px",
        "confidence"
      ],
      "properties": {
        "arrow_id": {"type": "string"},
        "rgb": {"type": "array", "items": {"type": "integer"}, "minItems": 3, "maxItems": 3},
        "bbox": {"type": "array", "items": {"type": "integer"}, "minItems": 4, "maxItems": 4},
        "tail_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "head_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "angle_degrees": {"type": "number", "minimum": 0, "exclusiveMaximum": 360},
        "length_px": {"type": "number", "minimum": 0},
        "tail_spread_px": {"type": "number", "minimum": 0},
        "head_spread_px": {"type": "number", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "label_text": {"type": ["string", "null"]},
        "label_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "region": {
      "type": "object",
      "required": ["region_id", "kind", "bbox", "pixel_count", "confidence"],
      "properties": {
        "region_id": {"type": "string"},
        "kind": {"type": "string"},
        "bbox": {"type": "array", "items": {"type": "integer"}, "minItems": 4, "maxItems": 4},
        "pixel_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
