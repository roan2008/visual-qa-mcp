{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-qa-mcp.local/schemas/geometry-evidence-graph.schema.json",
  "title": "GeometryEvidenceGraph",
  "type": "object",
  "required": [
    "image_id",
    "diagram_type",
    "holes",
    "regions",
    "extraction_confidence",
    "provenance",
    "gaps",
    "metadata"
  ],
  "properties": {
    "image_id": {"type": "string"},
    "diagram_type": {"type": "string"},
    "holes": {
      "type": "array",
      "items": {"$ref": "#/$defs/hole"}
    },
    "regions": {
      "type": "array",
      "items": {"$ref": "#/$defs/region"}
    },
    "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {
      "type": "object",
      "required": ["extractor_id", "extractor_version", "backend", "metadata_source"],
      "properties": {
        "extractor_id": {"type": "string"},
        "extractor_version": {"type": "string"},
        "backend": {"type": "string"},
        "metadata_source": {"type": "string"},
        "dependency_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "environment": {"type": "object", "additionalProperties": true}
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "check_ids"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "check_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "hole": {
      "type": "object",
      "required": [
        "hole_id",
        "center_xy",
        "diameter_px",
        "circularity",
        "bbox",
        "pixel_count",
        "confidence",
        "label_text",
        "label_confidence"
      ],
      "properties": {
        "hole_id": {"type": "string"},
        "center_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "diameter_px": {"type": "number", "minimum": 0},
        "circularity": {"type": "number", "minimum": 0},
        "bbox": {"type": "array", "items": {"type": "integer"}, "minItems": 4, "maxItems": 4},
        "pixel_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "label_text": {"type": ["string", "null"]},
        "label_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "region": {
      "type": "object",
      "required": ["region_id", "kind", "bbox", "pixel_count", "confidence"],
      "properties": {
        "region_id": {"type": "string"},
        "kind": {"type": "string"},
        "bbox": {"type": "array", "items": {"type": "integer"}, "minItems": 4, "maxItems": 4},
        "pixel_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
