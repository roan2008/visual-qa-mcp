{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-qa-mcp.local/schemas/flowchart-evidence-graph.schema.json",
  "title": "FlowchartEvidenceGraph",
  "type": "object",
  "required": [
    "image_id",
    "diagram_type",
    "nodes",
    "connectors",
    "extraction_confidence",
    "provenance",
    "gaps",
    "metadata"
  ],
  "properties": {
    "image_id": {"type": "string"},
    "diagram_type": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {"$ref": "#/$defs/node"}
    },
    "connectors": {
      "type": "array",
      "items": {"$ref": "#/$defs/connector"}
    },
    "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {
      "type": "object",
      "required": ["extractor_id", "extractor_version", "backend", "metadata_source"],
      "properties": {
        "extractor_id": {"type": "string"},
        "extractor_version": {"type": "string"},
        "backend": {"type": "string"},
        "metadata_source": {"type": "string"},
        "dependency_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "environment": {"type": "object", "additionalProperties": true}
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "check_ids"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "check_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "node_id",
        "shape",
        "rgb",
        "bbox",
        "center_xy",
        "pixel_count",
        "fill_ratio",
        "confidence"
      ],
      "properties": {
        "node_id": {"type": "string"},
        "shape": {"type": "string", "enum": ["rectangle", "diamond"]},
        "rgb": {"type": "array", "items": {"type": "integer"}, "minItems": 3, "maxItems": 3},
        "bbox": {"type": "array", "items": {"type": "integer"}, "minItems": 4, "maxItems": 4},
        "center_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "pixel_count": {"type": "integer", "minimum": 0},
        "fill_ratio": {"type": "number", "minimum": 0, "maximum": 1.5},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "label_text": {"type": ["string", "null"]},
        "label_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "connector": {
      "type": "object",
      "required": [
        "connector_id",
        "tail_xy",
        "head_xy",
        "from_node_id",
        "to_node_id",
        "length_px",
        "confidence"
      ],
      "properties": {
        "connector_id": {"type": "string"},
        "tail_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "head_xy": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "from_node_id": {"type": ["string", "null"]},
        "to_node_id": {"type": ["string", "null"]},
        "length_px": {"type": "number", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "primitive_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
